{
  "manifest_version": 3,
  "name": "LMS AI Assistant",
  "version": "1.0.0",
  "description": "Ask questions about LMS lectures, modules, files, and assignments.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "http://localhost:5173/*",
    "http://localhost:5000/*",
    "http://localhost:6001/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LMS AI Assistant"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["content.js"]
    }
  ]
}